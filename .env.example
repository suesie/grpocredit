# Copy to .env and fill in.
WANDB_API_KEY=
WANDB_PROJECT=grpo-voi
WANDB_ENTITY=
WANDB_MODE=online   # set to `offline` on air-gapped clusters; `wandb sync` later

# HuggingFace cache (point at fast scratch on cluster nodes)
HF_HOME=./.cache/hf
TRANSFORMERS_CACHE=./.cache/hf
HF_DATASETS_CACHE=./.cache/hf_datasets

# Model access (if gated weights)
HF_TOKEN=
